        <span class="right"><span class="brand"><img class="logo-gradus" alt="Gradus"></span><span class="pageno">6</span></span>
      </footer>
    </section>

    <!-- EXEMPLO renderResumoGeral: tabela balanceada em 2 colunas com subtotais + total geral.
         NÃO existia na v3 — implementada conforme padrão de tabela do §11.3 da spec. -->
    <section class="slide" data-id="ex-resumo-geral" data-role="visao-geral-conta"
             data-render="resumoGeral" data-target="rg-host">
      <span class="badge" data-badge="BACKUP">BACKUP</span>
      <h1 class="lead" contenteditable="true">Resumo geral por agrupamento &mdash; subtotais e total geral reconciliam</h1>
      <div class="subhead" contenteditable="true">R$ MM/ano &middot; tabela balanceada em 2 colunas</div>
      <div class="canvas">
        <div id="rg-host" class="canvas-tbl-wrap" style="align-items:flex-start; gap:32px;"><!-- EXEMPLO: a skill injeta agrupamentos reais aqui (renderResumoGeral) --></div>
      </div>
      <footer class="foot">
        <span class="src" contenteditable="true">Fonte: dado-exemplo (placeholder) &mdash; a skill injeta os agrupamentos reais</span>
        <span class="right"><span class="brand"><img class="logo-gradus" alt="Gradus"></span><span class="pageno">7</span></span>
