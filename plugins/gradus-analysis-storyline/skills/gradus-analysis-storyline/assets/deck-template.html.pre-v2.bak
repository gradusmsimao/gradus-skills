  </div>
</div>

<!-- ============================================================
     MAPA-MESTRE — drawer flutuante (controle de classificação)
     ============================================================ -->
<div class="master-drawer" id="master-drawer">
  <h2>Mapa-mestre de análises do pacote</h2>
  <p class="hint">
    Toda análise nasce como <strong>Preliminar</strong> e tem valor real calculado no slide.
    Para entrar no placar e nos mapas-de-análises por conta, promova para <strong>Adicional</strong> ou <strong>Validada</strong>.
    Preliminares contam como R$ 0 nos agregados.
  </p>
  <table>
    <thead>
      <tr><th>Análise</th><th>Conta OM</th><th class="r">R$ calculado</th><th>Estado</th></tr>
    </thead>
    <tbody id="master-tbody">
      <!-- GEN: MASTER_ROWS — injetar uma linha por análise:
      <tr data-analysis-id="analise-001">
        <td>Comparação R$/min por cluster</td>
        <td>Rede Telefonia Terceira</td>
        <td class="r">R$ 3,2 MM</td>
        <td>
          <div class="toggle-3" data-analysis-id="analise-001">
            <button data-state="preliminar" class="on">Preliminar</button>
            <button data-state="adicional">Adicional</button>
            <button data-state="validada">Validada</button>
          </div>
        </td>
      </tr>
      -->

      <tr data-analysis-id="a1"><td>Comparação R$/min por cluster</td><td>Rede Telefonia Terceira</td><td class="r">R$ 3,2 MM</td>
        <td><div class="toggle-3" data-analysis-id="a1">
          <button data-state="preliminar" class="on">Preliminar</button>
          <button data-state="adicional">Adicional</button>
          <button data-state="validada">Validada</button>
        </div></td>
      </tr>

    </tbody>
  </table>
  <div class="master-totals" id="master-totals">
    <div class="row"><span>Total Validadas:</span> <strong id="tot-validada">R$ 0,0 MM</strong></div>
    <div class="row"><span>Total Adicionais:</span> <strong id="tot-adicional">R$ 0,0 MM</strong></div>
    <div class="row" style="color:var(--grey-mid);"><span>Preliminares (fora do placar):</span> <strong id="tot-preliminar">R$ 0,0 MM</strong></div>
  </div>
</div>

<!-- ============================================================
     ANALYSIS-DRAWER — controles da análise viva (Modo A)
     ============================================================ -->
<div class="analysis-drawer" id="analysis-drawer">
  <h2>Controles da análise</h2>
  <p class="hint">Modo A &mdash; o callout recomputa ao vivo (computeBenchmarks + computeOportunidade). A skill injeta as unidades reais.</p>
  <div class="ctrl">
    <label for="av-cluster">Dimensões de cluster</label>
    <select id="av-cluster" multiple size="3"><!-- GEN: dims --></select>
  </div>
  <div class="ctrl">
    <label for="av-meta">Meta (benchmark)</label>
    <select id="av-meta">
      <option value="median">Mediana (P50) &mdash; conservadora</option>
      <option value="q1">1º quartil (P25) &mdash; agressiva</option>
    </select>
  </div>
  <div class="ctrl">
    <label for="av-cap">Cap de compressão (%)</label>
    <div class="row-inline">
      <input type="number" id="av-cap" min="0" max="100" step="5" value="30">
      <label style="display:flex;align-items:center;gap:5px;font-weight:400;"><input type="checkbox" id="av-cap-on" checked> aplicar</label>
    </div>
  </div>
  <div class="ctrl">
    <label for="av-maxbars">maxBars (nº de barras do ranking/tornado)</label>
    <input type="number" id="av-maxbars" min="3" max="60" step="1" value="12">
  </div>
  <div class="recompute-out" id="av-out">
    <div>Oportunidade calculada</div>
    <div class="big" id="av-out-val">R$ 0,0 MM</div>
    <div id="av-out-note" style="font-size:9.5pt;color:var(--grey-mid);margin-top:4px;"></div>
  </div>
</div>

<script>
/* ============================================================
   7b. LOGO BASE64 — PNG marca-positiva da Gradus (skill irmã)
   ============================================================ */
const GRADUS_LOGO_DATA_URL = "data:image/png;base64,"; // GEN: substituir pela data URL real do logo Gradus (PNG base64). Ver /assets/logos/

function applyLogos(){
  if(!GRADUS_LOGO_DATA_URL) return; // sem logo configurado ainda
  document.querySelectorAll('img.logo-gradus').forEach(img => {
    if(!img.src || img.src.length < 100) img.src = GRADUS_LOGO_DATA_URL;
  });
}

/* ============================================================
   8. ESTADO E PERSISTÊNCIA
   ============================================================ */
const STATE = {
  meta: { /* GEN: META — cliente, pacote, tema */ },
  slides: [],   /* GEN: SLIDES_JSON — array de slides com role/leadTitle/elements/params */
  analyses: [{id:"a1", name:"Comparação R$/min por cluster", conta:"Rede Telefonia Terceira", value:3.2, state:"preliminar"}], /* GEN: ANALYSES_JSON — array de análises pro mapa-mestre */
  textOverrides: {},
  currentSlide: 0
};

const LS_KEY = 'gradus-storyline-' + (location.pathname.split('/').pop() || 'default');

function loadState(){
  try{
    const saved = localStorage.getItem(LS_KEY);
    if(saved){
      const parsed = JSON.parse(saved);
      Object.assign(STATE, parsed);
      return true;
    }
  }catch(e){ console.warn('Falha ao carregar state:', e); }
  return false;
}

let saveTimer = null;
function saveState(){
  clearTimeout(saveTimer);
  saveTimer = setTimeout(() => {
    try{
      localStorage.setItem(LS_KEY, JSON.stringify(STATE));
    }catch(e){ console.warn('Falha ao salvar:', e); }
  }, 500); // debounce 500ms
}

function resetState(){
  if(!confirm('Resetar todas as edições para o original? Esta ação não pode ser desfeita.')) return;
  localStorage.removeItem(LS_KEY);
  location.reload();
}

/* ============================================================
   9. SCALE LETTERBOX — palco 1280×720 cabe na viewport
   ============================================================ */
function applyScale(){
  const stage = document.getElementById('stage');
  const wrap  = stage.parentElement;
  const availW = wrap.clientWidth;
  const availH = wrap.clientHeight;
  const scale = Math.min(availW / 1280, availH / 720);
  // scaled dimensions
  const scaledW = 1280 * scale;
  const scaledH = 720 * scale;
  // offset pra centralizar
  const offsetX = (availW - scaledW) / 2;
  const offsetY = (availH - scaledH) / 2;
  // ordem importa: translate primeiro, depois scale (com origin top-left)
  stage.style.transform = `translate(${offsetX}px, ${offsetY}px) scale(${scale})`;
}
window.addEventListener('resize', applyScale);

/* ============================================================
   10. NAVEGAÇÃO ENTRE SLIDES
   ============================================================ */
function getSlides(){ return document.querySelectorAll('.slide'); }

function showSlide(idx){
  const slides = getSlides();
  if(idx < 0) idx = 0;
  if(idx >= slides.length) idx = slides.length - 1;
  slides.forEach((s, i) => s.classList.toggle('active', i === idx));
  STATE.currentSlide = idx;
  document.getElementById('cur').textContent = idx + 1;
  document.getElementById('total').textContent = slides.length;
  renderActive();                 // dispatch dos renderers do slide ativo
  saveState();
}

document.addEventListener('keydown', (e) => {
  if(document.activeElement && document.activeElement.isContentEditable) return;
  if(e.key === 'ArrowRight' || e.key === 'PageDown') showSlide(STATE.currentSlide + 1);
  if(e.key === 'ArrowLeft'  || e.key === 'PageUp')   showSlide(STATE.currentSlide - 1);
});

/* botões prev/next bindados dentro de init() — ver §16 */

/* ============================================================
   11. EDIÇÃO INLINE — captura mudanças em [contenteditable]
   ============================================================ */
function bindEditable(){
  document.querySelectorAll('[contenteditable="true"]').forEach(el => {
    if(el.dataset.bound) return;
    el.dataset.bound = '1';
    const slide = el.closest('.slide');
    const sid = slide?.dataset.id || 'unknown';
    const key = `${sid}::${el.dataset.field || el.tagName + '-' + Array.from(slide.querySelectorAll('[contenteditable]')).indexOf(el)}`;

    // restaura override se houver
    if(STATE.textOverrides[key] !== undefined){
      el.textContent = STATE.textOverrides[key];
    }

    el.addEventListener('input', () => {
      STATE.textOverrides[key] = el.textContent;
      saveState();
      checkOverflow(slide);
    });

    el.addEventListener('blur', () => {
      el.scrollLeft = 0;
    });
  });
}

/* ============================================================
   11b. DRAG-AND-DROP — bubbles de oportunidade (callout-opp)
   ============================================================ */
function bindDraggable(){
  document.querySelectorAll('.callout-opp').forEach(el => {
    if(el.dataset.draggableBound) return;
    el.dataset.draggableBound = '1';
    const slide = el.closest('.slide');
    const sid = slide?.dataset.id || 'unknown';
    // chave persistente da posição do bubble
    const idx = Array.from(slide.querySelectorAll('.callout-opp')).indexOf(el);
    const posKey = `${sid}::callout-pos-${idx}`;

    // restaura posição salva
    const saved = STATE.textOverrides[posKey];
    if(saved){
      try{
        const {left, top} = JSON.parse(saved);
        el.style.left = left + 'px';
        el.style.top = top + 'px';
        el.style.right = 'auto';
        el.style.bottom = 'auto';
      }catch(e){}
    }

    el.addEventListener('mousedown', (e) => {
      if(e.target !== el && e.target.isContentEditable) return;
      // se clicou no resize handle (canto inferior direito ~16px), não inicia drag
      // deixa o resize nativo do CSS funcionar
      const rect = el.getBoundingClientRect();
      const inResizeCorner = (rect.right - e.clientX < 16) && (rect.bottom - e.clientY < 16);
      if(inResizeCorner) return;
      e.preventDefault();
      el.classList.add('dragging');

      const stage = document.getElementById('stage');
      const stageRect = stage.getBoundingClientRect();
      const scale = stageRect.width / 1280;

      // posição inicial do bubble no palco (coords não-escaladas)
      // pega da style atual OU do offsetLeft/offsetTop (que já estão em coords do palco)
      let startLeft = parseFloat(el.style.left);
      let startTop = parseFloat(el.style.top);
      if(isNaN(startLeft)) startLeft = el.offsetLeft;
      if(isNaN(startTop)) startTop = el.offsetTop;

      // posição inicial do mouse em coords de tela
      const startMouseX = e.clientX;
      const startMouseY = e.clientY;

      function onMove(ev){
        // delta do mouse em coords de tela → converter pra coords do palco dividindo por scale
        const dxStage = (ev.clientX - startMouseX) / scale;
        const dyStage = (ev.clientY - startMouseY) / scale;
        const w = el.offsetWidth, h = el.offsetHeight;
        const x = Math.max(0, Math.min(1280 - w, startLeft + dxStage));
        const y = Math.max(0, Math.min(720 - h, startTop + dyStage));
        el.style.left = x + 'px';
        el.style.top = y + 'px';
        el.style.right = 'auto';
        el.style.bottom = 'auto';
      }

      function onUp(){
        el.classList.remove('dragging');
        const x = parseFloat(el.style.left) || 0;
        const y = parseFloat(el.style.top) || 0;
        STATE.textOverrides[posKey] = JSON.stringify({left: x, top: y});
        saveState();
        document.removeEventListener('mousemove', onMove);
        document.removeEventListener('mouseup', onUp);
      }

      document.addEventListener('mousemove', onMove);
      document.addEventListener('mouseup', onUp);
    });
  });
}

/* ============================================================
   11c. CRIAR BUBBLE CUSTOM — cor navy, draggável, resizível, texto editável
   ============================================================ */
let bubbleCounter = 0;
function createBubble(){
  // identifica o slide ativo
  const slide = document.querySelector('.slide.active');
  if(!slide){
    alert('Nenhum slide ativo.');
    return;
  }
  // canvas onde o bubble vai entrar (preferencial) ou direto no slide
  const canvas = slide.querySelector('.canvas') || slide;
  // posição inicial: centro aproximado
  const left = 540, top = 280;
  bubbleCounter += 1;
  const id = `custom-bubble-${Date.now()}-${bubbleCounter}`;

  const div = document.createElement('div');
  div.className = 'callout-opp custom-navy';
  div.id = id;
  div.style.left = left + 'px';
  div.style.top = top + 'px';
  div.style.width = '182px';
  div.style.height = '86px';
  div.dataset.customBubble = '1'; // marca pra identificar bubbles removíveis

  // estrutura interna: span do texto + botão X
  const textSpan = document.createElement('span');
  textSpan.className = 'bubble-text';
  textSpan.textContent = 'Texto livre…';
  div.appendChild(textSpan);

  const xBtn = document.createElement('div');
  xBtn.className = 'bubble-delete';
  xBtn.textContent = '×';
  xBtn.title = 'Remover bubble';
  xBtn.addEventListener('mousedown', (ev) => ev.stopPropagation()); // não dispara drag
  xBtn.addEventListener('click', (ev) => {
    ev.stopPropagation();
    div.remove();
    // limpa overrides associados
    Object.keys(STATE.textOverrides).forEach(k => {
      if(k.startsWith(id + '::')) delete STATE.textOverrides[k];
    });
    saveState();
  });
  div.appendChild(xBtn);

  div.setAttribute('contenteditable', 'false');
  canvas.appendChild(div);

  // selecionar bubble ao clicar (mostra o X e habilita Delete via teclado)
  div.addEventListener('mousedown', (e) => {
    document.querySelectorAll('.callout-opp.custom-navy.selected').forEach(b => b.classList.remove('selected'));
    div.classList.add('selected');
  });

  // double-click → entra em modo edição (no textSpan, não no div inteiro)
  div.addEventListener('dblclick', (e) => {
    e.stopPropagation();
    div.classList.add('editing');
    textSpan.setAttribute('contenteditable', 'true');
    textSpan.focus();
    const range = document.createRange();
    range.selectNodeContents(textSpan);
    const sel = window.getSelection();
    sel.removeAllRanges();
    sel.addRange(range);
  });

  // blur do texto → sai do modo edição e salva
  textSpan.addEventListener('blur', () => {
    div.classList.remove('editing');
    textSpan.setAttribute('contenteditable', 'false');
    const key = `${id}::text`;
    STATE.textOverrides[key] = textSpan.textContent;
    saveState();
  });

  bindDraggable();

  setTimeout(() => {
    div.dispatchEvent(new MouseEvent('dblclick', { bubbles: true }));
  }, 50);
}

// tecla Delete/Backspace remove bubble selecionado
document.addEventListener('keydown', (e) => {
  if(e.key !== 'Delete' && e.key !== 'Backspace') return;
  // se está editando texto em qualquer lugar, não remove
  if(document.activeElement && document.activeElement.isContentEditable) return;
  const selected = document.querySelector('.callout-opp.custom-navy.selected');
  if(selected){
    e.preventDefault();
    const id = selected.id;
    selected.remove();
    Object.keys(STATE.textOverrides).forEach(k => {
      if(k.startsWith(id + '::')) delete STATE.textOverrides[k];
    });
    saveState();
  }
});

// click fora do bubble → deseleciona
document.addEventListener('mousedown', (e) => {
  if(!e.target.closest('.callout-opp.custom-navy')){
    document.querySelectorAll('.callout-opp.custom-navy.selected').forEach(b => b.classList.remove('selected'));
  }
});

/* ============================================================
   12. GUARD DE OVERFLOW — sinaliza se conteúdo extrapola 720px
   ============================================================ */
function checkOverflow(slide){
  if(!slide) return;
  // tolerância de 2px (arredondamento de subpixel em browsers diferentes)
  const overflow = slide.scrollHeight > 722;
  slide.style.outline = overflow ? '3px solid var(--red)' : '';
  if(overflow){
    console.warn(`Overflow no slide ${slide.dataset.id}: scrollHeight=${slide.scrollHeight}`);
  }
}

/* ============================================================
   12b. UTIL DE FORMATAÇÃO (pt-BR) — usado pelos renderers
   ============================================================ */
const FMT = {
  mm: (v, dec=1) => 'R$ ' + Number(v).toLocaleString('pt-BR', {minimumFractionDigits:dec, maximumFractionDigits:dec}) + ' MM',
  num: (v, dec=1) => Number(v).toLocaleString('pt-BR', {minimumFractionDigits:dec, maximumFractionDigits:dec}),
  pct: (v, dec=1) => Number(v).toLocaleString('pt-BR', {minimumFractionDigits:dec, maximumFractionDigits:dec}) + '%'
};
function median(arr){
  const a = arr.slice().sort((x,y)=>x-y); const n=a.length; if(!n) return 0;
  return n%2 ? a[(n-1)/2] : (a[n/2-1]+a[n/2])/2;
}
function quantile(arr, q){
  const a = arr.slice().sort((x,y)=>x-y); const n=a.length; if(!n) return 0;
  const pos = (n-1)*q, base = Math.floor(pos), rest = pos-base;
  return a[base] + (a[base+1]!==undefined ? rest*(a[base+1]-a[base]) : 0);
}

/* ============================================================
   12c. renderTornado(svgId, data, cfg) — RANKING SVG PURO (sem lib)
   Generaliza o ranking ordenado do v3 (renderV1) p/ SVG handcrafted:
   barras horizontais ordenadas + ref-line (mediana/Q1) + labels rotacionados
   + seta "menos eficiente" + tooltip navy.
   data: [{label, valor, ...}]   cfg: {meta, maxBars, indLabel, ...}
   🔒 R6: NADA hardcoded — maxBars/casas/ref vêm de cfg.
   ============================================================ */
function renderTornado(svgId, data, cfg){
  const svg = document.getElementById(svgId); if(!svg) return;
  cfg = cfg || {};
  const maxBars = (cfg.maxBars != null) ? cfg.maxBars : 12;   // R6: parâmetro, nunca literal
  const dec     = (cfg.dec != null) ? cfg.dec : 1;
  const indLabel = cfg.indLabel || 'indicador';
  const metaKind = cfg.meta || 'median';                      // 'median' | 'q1' | número absoluto
  const VBW = 1180, VBH = 470;                                // viewBox lógico do SVG do slide
  const NS = 'http://www.w3.org/2000/svg';

  // ordena desc por valor e trunca a maxBars (resto colapsa em "Outros (N)")
  const all = data.slice().filter(d => d && isFinite(d.valor)).sort((a,b)=> b.valor - a.valor);
  let rows = all.slice(0, maxBars);
  const rest = all.slice(maxBars);
  if(rest.length){
    const soma = rest.reduce((a,d)=>a+d.valor, 0);
    rows = rows.concat([{ label:`Outros (${rest.length})`, valor:soma, _outros:true }]);
  }

  // ref-line (mediana/Q1 do dataset COMPLETO — não do truncado)
  const vals = all.map(d=>d.valor);
  let refVal;
  if(typeof metaKind === 'number') refVal = metaKind;
  else if(metaKind === 'q1')       refVal = quantile(vals, 0.25);
  else                              refVal = median(vals);

  // geometria
  const padL = 250, padR = 60, padT = 24, padB = 64;
  const plotW = VBW - padL - padR, plotH = VBH - padT - padB;
  const n = rows.length;
  const bandH = plotH / n, barH = Math.min(bandH * 0.62, 26);
  const vmax = Math.max(refVal, ...rows.map(r=>r.valor), 1);
  const x = v => padL + (v / vmax) * plotW;

  while(svg.firstChild) svg.removeChild(svg.firstChild);
  const add = (tag, attrs, txt) => {
    const e = document.createElementNS(NS, tag);
    for(const k in attrs) e.setAttribute(k, attrs[k]);
    if(txt != null) e.textContent = txt;
    svg.appendChild(e);
    return e;
  };
  svg.setAttribute('viewBox', `0 0 ${VBW} ${VBH}`);

  // eixo base
  add('line', {x1:padL, y1:padT, x2:padL, y2:padT+plotH, stroke:'#A5A5A5', 'stroke-width':1});

  // barras + labels + valores
  rows.forEach((r, i) => {
    const cy = padT + i*bandH + bandH/2;
    const w = Math.max(0, x(r.valor) - padL);
    const col = r._outros ? '#9DB1CF' : (r.valor >= refVal ? (cfg.colorOver || '#800000') : (cfg.colorUnder || '#306F9F'));
    // rótulo da categoria (à esquerda, sem rotação quando cabe)
    add('text', {x:padL-10, y:cy+4, 'text-anchor':'end', fill:'#12376C', 'font-size':12,
                 'font-weight':r._outros?'400':'700', 'font-style':r._outros?'italic':'normal'}, r.label);
    // barra
    const rect = add('rect', {x:padL, y:cy-barH/2, width:w, height:barH, fill:col, rx:1});
    rect.setAttribute('data-label', r.label);
    rect.setAttribute('data-valor', r.valor);
    // valor à direita
    add('text', {x:x(r.valor)+6, y:cy+4, 'text-anchor':'start', fill:'#12376C', 'font-size':11, 'font-weight':'700'},
        FMT.num(r.valor, dec));
  });

  // ref-line (mediana/Q1) — vertical, vermelha tracejada + rótulo rotacionado
  const rx = x(refVal);
  add('line', {x1:rx, y1:padT-2, x2:rx, y2:padT+plotH+6, stroke:'#C00000', 'stroke-width':2, 'stroke-dasharray':'6 4'});
  const refTxt = (metaKind==='q1'?'Q1':'mediana') + ' ' + FMT.num(refVal, dec);
  add('text', {x:rx, y:padT-6, 'text-anchor':'middle', fill:'#C00000', 'font-size':11, 'font-weight':'700',
               transform:`rotate(-60 ${rx} ${padT-6})`}, refTxt);

  // eixo X label + seta "menos eficiente →" (aponta p/ os maiores valores = pior)
  add('text', {x:padL + plotW/2, y:VBH-26, 'text-anchor':'middle', fill:'#7B8EA0', 'font-size':11}, indLabel);
  const ay = VBH-44;
  const arrow = add('line', {x1:padL+plotW*0.55, y1:ay, x2:padL+plotW, y2:ay, stroke:'#800000', 'stroke-width':2,
                             'marker-end':'url(#tornadoArrow)'});
  const defs = document.createElementNS(NS, 'defs');
  const mk = document.createElementNS(NS, 'marker');
  mk.setAttribute('id','tornadoArrow'); mk.setAttribute('markerWidth','9'); mk.setAttribute('markerHeight','9');
  mk.setAttribute('refX','6'); mk.setAttribute('refY','3'); mk.setAttribute('orient','auto');
  const ap = document.createElementNS(NS,'path'); ap.setAttribute('d','M0,0 L7,3 L0,6 Z'); ap.setAttribute('fill','#800000');
  mk.appendChild(ap); defs.appendChild(mk); svg.insertBefore(defs, svg.firstChild);
  add('text', {x:padL+plotW*0.55-6, y:ay+4, 'text-anchor':'end', fill:'#800000', 'font-size':10, 'font-weight':'700'}, 'menos eficiente');

  // tooltip navy (HTML overlay sobre o slide)
  bindTornadoTooltip(svg, indLabel, dec);
}

function bindTornadoTooltip(svg, indLabel, dec){
  const slide = svg.closest('.slide'); if(!slide) return;
  let tip = slide.querySelector('.tornado-tt');
  if(!tip){
    tip = document.createElement('div'); tip.className = 'tornado-tt';
    tip.style.cssText = 'position:absolute;pointer-events:none;z-index:50;background:#002060;color:#fff;'+
      'border-radius:5px;padding:6px 9px;font-family:var(--font);font-size:10pt;font-weight:700;'+
      'opacity:0;transition:opacity .08s;white-space:nowrap;box-shadow:0 4px 14px rgba(0,0,0,.3);';
    slide.appendChild(tip);
  }
  svg.querySelectorAll('rect[data-label]').forEach(rect => {
    rect.style.cursor = 'pointer';
    rect.onmousemove = (e) => {
      const sr = slide.getBoundingClientRect(); const sc = sr.width/1280;
      tip.innerHTML = `${rect.getAttribute('data-label')}<br><span style="font-weight:400">${indLabel}:</span> ${FMT.num(+rect.getAttribute('data-valor'), dec)}`;
      tip.style.opacity = 1;
      tip.style.left = ((e.clientX - sr.left)/sc + 12) + 'px';
      tip.style.top  = ((e.clientY - sr.top)/sc - 10) + 'px';
    };
    rect.onmouseleave = () => { tip.style.opacity = 0; };
  });
}

/* ============================================================
   12d. renderBuildup(containerId, bars, {focusIndex, ...}) — WATERFALL
   Porte do renderWaterfall do v3, generalizado. Desenha barras flutuantes +
   conectores pontilhados + faixa "% do pacote" + shade na barra-foco.
   🔒 R3: o shade é FILHO do containerId (container relativo das barras), nunca de .canvas.
   bars: [{n:'rótulo', v:valor}]   opts: {focusIndex, total, totalLabel, pctBase, scaleMax,
                                          barColors, totalColor, pctLabel, labelsId, pctId}
   ============================================================ */
function renderBuildup(containerId, bars, opts){
  const el = document.getElementById(containerId); if(!el) return;
  opts = opts || {};
  const n = bars.length;
  const W = el.clientWidth || 810;
  const H = 380;                                              // §11.6: altura do gráfico
  const reserveL = 0;                                         // labels ficam em containers irmãos
  const total = (opts.total != null) ? opts.total : bars.reduce((a,b)=>a+b.v, 0);
  const totalLabel = opts.totalLabel || 'Total';
  const pctBase = (opts.pctBase != null) ? opts.pctBase : total;
  const barColors = opts.barColors || null;
  const totalColor = opts.totalColor || 'var(--blue-light)';  // §11.6: TODAS azul-light por padrão
  const pctLabel = opts.pctLabel || '% do pacote';
  const focusIndex = (opts.focusIndex != null) ? opts.focusIndex : -1;

  // geometria: barras 90px, gap, +1 coluna p/ Total separado
  const bw = 90;
  const slots = n + 1;                                        // +1 = coluna Total
  const usable = W - reserveL;
  const step = Math.min(140, usable / (slots + 0.2));         // centro-a-centro
  const x0 = reserveL + (usable - (slots*step)) / 2 + (step - bw)/2;
  const maxTop = (opts.scaleMax != null) ? opts.scaleMax : total;
  const scale = (H - 30) / maxTop;

  el.style.position = 'relative';
  el.style.height = H + 'px';
  el.innerHTML = '';
  const mkdiv = (style) => { const d = document.createElement('div'); d.style.cssText = style; el.appendChild(d); return d; };

  // shade da barra-foco — 🔒 R3: filho de EL (container das barras)
  if(focusIndex >= 0 && focusIndex <= n){
    const fx = x0 + focusIndex*step - 12;
    mkdiv(`position:absolute; left:${fx}px; top:0; width:${bw+24}px; height:${H}px; background:var(--grey-shade); z-index:0;`);
  }

  // barras de decomposição (flutuantes) + valores + conectores
  let cum = 0;
  const tx = x0 + n*step;                                     // X da barra Total
  bars.forEach((b, i) => {
    const h = Math.abs(b.v) * scale;
    const bb = (b.v >= 0 ? cum : cum + b.v) * scale;
    const xx = x0 + i*step;
    const col = (barColors && barColors[i]) ? barColors[i] : 'var(--blue-light)';
    mkdiv(`position:absolute; left:${xx}px; bottom:${bb}px; width:${bw}px; height:${h}px; background:${col}; z-index:1;`);
    const numTxt = b.v < 0 ? '('+FMT.num(Math.abs(b.v))+')' : FMT.num(b.v);
    if(bb > 0.5){
      const lbl = mkdiv(`position:absolute; left:${xx}px; bottom:${bb+h/2}px; transform:translateY(50%); width:${bw}px; text-align:center; font-weight:700; font-size:10pt; color:var(--navy); z-index:2;`);
      lbl.setAttribute('contenteditable','true'); lbl.textContent = numTxt;
    } else {
      const lbl = mkdiv(`position:absolute; left:${xx}px; bottom:${bb+h+4}px; width:${bw}px; text-align:center; font-weight:700; font-size:10pt; color:var(--navy); z-index:2;`);
      lbl.setAttribute('contenteditable','true'); lbl.textContent = numTxt;
    }
    cum += b.v;
    const cy = cum * scale;
    if(i < n-1) mkdiv(`position:absolute; left:${xx+bw}px; bottom:${cy}px; width:${step-bw}px; border-top:1px dashed var(--navy); z-index:1;`);
    else        mkdiv(`position:absolute; left:${xx+bw}px; bottom:${cy}px; width:${tx-(xx+bw)}px; border-top:1px dashed var(--navy); z-index:1;`);
  });

  // barra Total (cheia, separada)
  const th = total * scale;
  mkdiv(`position:absolute; left:${tx}px; bottom:0; width:${bw}px; height:${th}px; background:${totalColor}; z-index:1;`);
  const totLbl = mkdiv(`position:absolute; left:${tx}px; bottom:${th+4}px; width:${bw}px; text-align:center; font-weight:700; font-size:10.5pt; color:var(--navy); z-index:2;`);
  totLbl.setAttribute('contenteditable','true'); totLbl.innerHTML = `<b>${FMT.num(total)}</b>`;

  // labels das barras (container irmão)
  const labels = opts.labelsId ? document.getElementById(opts.labelsId) : null;
  if(labels){
    labels.style.position='relative'; labels.innerHTML='';
    bars.forEach((b,i)=>{ const xx=x0+i*step;
      const d=document.createElement('div'); d.style.cssText=`position:absolute; left:${xx}px; top:0; width:${bw}px; text-align:center; font-size:10pt; color:var(--navy); line-height:1.2;`;
      d.setAttribute('contenteditable','true'); d.innerHTML=b.n; labels.appendChild(d); });
    const dt=document.createElement('div'); dt.style.cssText=`position:absolute; left:${tx}px; top:0; width:${bw}px; text-align:center; font-size:10pt; font-weight:700; color:var(--navy);`;
    dt.setAttribute('contenteditable','true'); dt.textContent=totalLabel; labels.appendChild(dt);
  }

  // faixa "% do pacote" (container irmão)
  const pctEl = opts.pctId ? document.getElementById(opts.pctId) : null;
  if(pctEl){
    pctEl.style.position='relative'; pctEl.innerHTML='';
    const head=document.createElement('div'); head.style.cssText='position:absolute; left:0; top:0; width:80px; font-size:10pt; font-weight:700; color:var(--navy); font-style:italic;';
    head.className='it'; head.setAttribute('contenteditable','true'); head.textContent=pctLabel; pctEl.appendChild(head);
    bars.forEach((b,i)=>{ const xx=x0+i*step; const p=b.v/pctBase*100;
      const d=document.createElement('div'); d.style.cssText=`position:absolute; left:${xx}px; top:0; width:${bw}px; text-align:center; font-size:10pt; color:var(--navy);`;
      d.setAttribute('contenteditable','true'); d.textContent = (p<0?'('+Math.abs(p).toFixed(1)+'%)':p.toFixed(1)+'%'); pctEl.appendChild(d); });
    const totPct = (opts.pctBase != null) ? (total/pctBase*100).toFixed(1)+'%' : '100%';
    const dt=document.createElement('div'); dt.style.cssText=`position:absolute; left:${tx}px; top:0; width:${bw}px; text-align:center; font-size:10pt; font-weight:700; color:var(--navy);`;
    dt.setAttribute('contenteditable','true'); dt.textContent=totPct; pctEl.appendChild(dt);
  }
}

/* ============================================================
   12e. renderResumoGeral(hostId, groups, cfg) — TABELA Dir×Regional 2 COLUNAS
   NÃO existia na v3. Implementado conforme padrão de tabela do §11.3:
   balanceia os agrupamentos em 2 colunas, cada coluna com subtotais por grupo
   e a tabela inteira fecha com TOTAL GERAL (reconciliação §1.2).
   groups: [{nome, linhas:[{label, valor}]}]   cfg: {valLabel, grpLabel, dec}
   ============================================================ */
function renderResumoGeral(hostId, groups, cfg){
  const host = document.getElementById(hostId); if(!host) return;
  cfg = cfg || {};
  const dec = (cfg.dec != null) ? cfg.dec : 1;
  const valLabel = cfg.valLabel || 'Valor';
  const grpLabel = cfg.grpLabel || 'Agrupamento';

  // balanceia em 2 colunas equilibrando o nº total de LINHAS (subtotal conta como 1)
  const weight = g => g.linhas.length + 1;
  const totalW = groups.reduce((a,g)=>a+weight(g), 0);
  const colA = [], colB = []; let wA = 0;
  groups.forEach(g => { if(wA < totalW/2 || colB.length===0 && groups.indexOf(g)===groups.length-1){ colA.push(g); wA += weight(g); } else colB.push(g); });
  if(!colB.length && colA.length > 1) colB.push(colA.pop());

  const colTbl = (cols) => {
    let body = '';
    cols.forEach(g => {
      g.linhas.forEach(l => {
        body += `<tr><td contenteditable="true">${l.label}</td><td class="computed num">${FMT.num(l.valor, dec)}</td></tr>`;
      });
      const sub = g.linhas.reduce((a,l)=>a+l.valor, 0);
      body += `<tr class="subtotal"><td>${g.nome}</td><td class="computed num">${FMT.num(sub, dec)}</td></tr>`;
    });
    return `<table class="tbl"><thead><tr><th>${grpLabel}</th><th class="num">${valLabel}</th></tr></thead><tbody>${body}</tbody></table>`;
  };

  const grandTotal = groups.reduce((a,g)=> a + g.linhas.reduce((s,l)=>s+l.valor,0), 0);
  host.innerHTML =
    `<div style="display:flex; gap:32px; align-items:flex-start;">` +
      `<div>${colTbl(colA)}</div>` +
      `<div>${colTbl(colB)}</div>` +
    `</div>`;
  // TOTAL GERAL embaixo, centralizado (reconcilia as duas colunas)
  const tot = document.createElement('div');
  tot.style.cssText = 'width:100%; text-align:center; margin-top:14px; font-weight:800; color:var(--navy); border-top:2px solid var(--navy); padding-top:8px;';
  tot.innerHTML = `Total geral &nbsp; <span class="computed">${FMT.num(grandTotal, dec)}</span>`;
  host.appendChild(tot);
}

/* ============================================================
   12f. ANÁLISE VIVA (Modo A) — esqueleto da spec §12.2 (nomes/semântica exatos).
   A v3 NÃO tem isto (números hardcoded). Vem da SPEC, com DADO-EXEMPLO.
   A skill injeta as unidades reais (units) e o método declarado.
   ============================================================ */

// makeBucketState(bucket) — estado independente de cada análise (spec §12.2)
function makeBucketState(bucket){
  return {
    bucket,
    indicador: 'r_10k_driver',   // r_loja | r_<drv> | r_10k_<drv>
    meta: 'median',              // 'median' (P50) | 'q1' (P25)
    cap: 30,
    capEnabled: true,
    maxBars: 41,                 // R6: drawer, nunca literal no render
    unidadeAnalise: 'loja',
    filters: { dir:[], reg:[], tipo:[], tam:[], clu:[], idd:[] },
    clusterDims: [],
    sortDetalhe: { col:'baseline', dir:'desc' },
    drillCluster: null,
    showAvisos: true,
    _lastUnits: null,
    _lastBenchmarks: null
  };
}

function clusterKey(u, state){
  return state.clusterDims.length ? state.clusterDims.map(d=>u[d]).join('|') : '__all__';
}

// computeBenchmarks(units, state) — referências por cluster (spec §12.2)
function computeBenchmarks(units, state){
  const indOf = u => {
    if(state.indicador === 'r_loja') return u.gasto;
    if(state.indicador.startsWith('r_10k_')) return u.driver>0 ? u.gasto/(u.driver/10000) : 0;
    return u.driver>0 ? u.gasto/u.driver : 0;
  };
  const groups = {};
  units.forEach(u => { const k = clusterKey(u, state); (groups[k] = groups[k] || []).push(indOf(u)); });
  const out = {};
  for(const k in groups){
    const arr = groups[k];
    out[k] = { n:arr.length, median:median(arr), q1:quantile(arr,0.25), q3:quantile(arr,0.75) };
  }
  state._lastBenchmarks = out;
  return out;
}

// computeOportunidade(unit, benchmarks, state) — fórmula canônica (spec §12.2 / §4.3)
function computeOportunidade(unit, benchmarks, state){
  const bench = benchmarks[clusterKey(unit, state)];
  if(!bench) return { oport:0, gastoMeta:0, benchInd:0 };
  const benchInd = bench[state.meta === 'q1' ? 'q1' : 'median'];
  const ind = (state.indicador === 'r_loja') ? unit.gasto
            : (state.indicador.startsWith('r_10k_')) ? (unit.driver>0 ? unit.gasto/(unit.driver/10000) : 0)
            : (unit.driver>0 ? unit.gasto/unit.driver : 0);
  if(ind <= benchInd) return { oport:0, gastoMeta:0, benchInd, ind };
  let gastoMeta;
  if(state.indicador === 'r_loja')              gastoMeta = benchInd;
  else if(state.indicador.startsWith('r_10k_')) gastoMeta = benchInd * (unit.driver/10000);
  else                                          gastoMeta = benchInd * unit.driver;
  const gapTeorico = Math.max(0, unit.gasto - gastoMeta);
  const oport = state.capEnabled ? Math.min(gapTeorico, unit.gasto * state.cap/100) : gapTeorico;
  return { oport, gastoMeta, benchInd, ind };
}

// estado vivo por bucket (a skill injeta units reais; aqui dado-exemplo)
const BUCKET_STATES = {};
function recomputeAnalise(bucket){
  const state = BUCKET_STATES[bucket]; if(!state) return 0;
  const units = state._lastUnits || [];
  const bench = computeBenchmarks(units, state);
  let oportTotal = 0;
  units.forEach(u => { oportTotal += computeOportunidade(u, bench, state).oport; });
  // atualiza callout do slide ativo + KPIs do drawer
  const slide = document.querySelector('.slide.active[data-bucket="'+bucket+'"]') || document.querySelector('.slide.active');
  if(slide){
    const callout = slide.querySelector('[data-av-callout]');
    if(callout) callout.innerHTML = 'Oportunidade<br>' + FMT.mm(oportTotal);
  }
  const ov = document.getElementById('av-out-val'); if(ov) ov.textContent = FMT.mm(oportTotal);
  const on = document.getElementById('av-out-note');
  if(on) on.textContent = `meta=${state.meta} · cap=${state.capEnabled?state.cap+'%':'off'} · cluster=${state.clusterDims.join('|')||'(todos)'} · maxBars=${state.maxBars} · N=${units.length}`;
  return oportTotal;
}

// bind dos controles do analysis-drawer -> mutam state -> recompute
function bindAnalysisDrawer(){
  const drw = document.getElementById('analysis-drawer'); if(!drw || drw.dataset.bound) return;
  drw.dataset.bound = '1';
  const cur = () => document.querySelector('.slide.active')?.dataset.bucket;
  const meta = document.getElementById('av-meta'), cap = document.getElementById('av-cap'),
        capOn = document.getElementById('av-cap-on'), maxB = document.getElementById('av-maxbars'),
        clu = document.getElementById('av-cluster');
  const sync = () => {
    const b = cur(); const st = BUCKET_STATES[b]; if(!st) return;
    st.meta = meta.value; st.cap = +cap.value; st.capEnabled = capOn.checked; st.maxBars = +maxB.value;
    st.clusterDims = Array.from(clu.selectedOptions).map(o=>o.value);
    recomputeAnalise(b);
  };
  [meta, cap, maxB].forEach(c => c.addEventListener('input', sync));
  capOn.addEventListener('change', sync);
  clu.addEventListener('change', sync);
}

/* ============================================================
   12g. DEMO DATA (placeholder) — a skill substitui por dados reais.
   <!-- EXEMPLO: a skill injeta dados reais aqui -->
   ============================================================ */
