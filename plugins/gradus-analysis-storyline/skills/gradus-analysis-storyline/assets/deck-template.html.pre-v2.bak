      <div class="subhead" contenteditable="true">MODO A &middot; abra os controles em "Analisar (controles)" no topo</div>
      <div class="canvas" style="padding-top:18px;">
        <div id="av-host" style="display:flex; gap:24px; height:100%;">
          <!-- EXEMPLO: a skill injeta unidades/drivers reais aqui (makeBucketState/computeBenchmarks/computeOportunidade) -->
        </div>
        <div class="callout-opp bubble" data-av-callout style="left:1010px; top:250px;">&mdash;</div>
      </div>
      <footer class="foot">
