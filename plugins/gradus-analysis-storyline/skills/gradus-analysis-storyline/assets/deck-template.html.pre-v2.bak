<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><!-- GEN: TITLE --></title>

<!-- ============================================================
     ESQUELETO DECK-MODE GRADUS — referenciado por SKILL.md
     1 slide = 1 .slide 16:9 (1280×720) com transform:scale() pra letterbox
     Edição inline + localStorage + mapa-mestre flutuante
     Pontos de injeção marcados com "GEN: ..."
     ============================================================ -->

<!-- Chart.js 4.4.1 via CDN (fallback offline: embutir em produção) -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>

<style>
/* ============================================================
   1. TOKENS GRADUS NOVA — fonte: design-tokens-per-template.md §0
   ============================================================ */
:root{
  /* cor — tema oficial */
  --navy:        #002060;
  --navy-2:      #12376C;
  --blue:        #306F9F;
  --blue-light:  #9DB1CF;
  --blue-light2: #C9D5E6;
  --orange:      #E68E18;
  --amber:       #FFC000;
  --red:         #C00000;
  --green:       #70AD47;
  --maroon:      #800000;
  --grey-shade:  #D9D9D9;
  --grey-mid:    #A5A5A5;
  --zebra:       #F2F2F2;
  --rule:        #9DB1CF;
  --ink:         #002060;
  --paper:       #FFFFFF;
  /* tipografia */
  --font: "Gadugi", "Segoe UI", Arial, sans-serif;
  --fs-lead: 20pt; --fs-sub: 13pt; --fs-body: 11pt; --fs-small: 9pt;
  /* geometria (fração do canvas 1280×720) */
  --pad-x: 1.4%;
  --title-h: 10%;
  --rule-y: 11.7%;
  --util-top: 12.2%; --util-bottom: 84%;
  --footer-y: 96.3%;
}

/* ============================================================
   2. SCAFFOLD — palco fixo + scale letterbox (no-scroll 16:9)
   ============================================================ */
*{ box-sizing:border-box; }
html, body{
  margin:0; padding:0;
  width:100%; height:100vh;
  background:#1a1a1a;
  font-family:var(--font);
  overflow:hidden;
}
.stage-wrap{
  width:100vw; height:calc(100vh - 48px);
  position:relative;
  overflow:hidden;
}
.stage{
  width:1280px; height:720px;
  background:var(--paper);
  position:absolute;
  top:0; left:0;
  transform-origin:top left;
  box-shadow:0 8px 32px rgba(0,0,0,.4);
}
/* JS faz o scale dinâmico + centralização via translate no resize.
   IMPORTANTE: transform-origin = top left. A centralização vem via
   translate dentro do mesmo transform (não via flex), pra eventos
   de click ficarem alinhados com a escala. */

/* ============================================================
   3. SLIDE BASE
   ============================================================ */
.slide{
  position:absolute; inset:0;
  color:var(--ink);
  display:none;
  /* Métricas extraídas do slideLayout2.xml do PPTX oficial:
     - title: x=18, y=5.6, w=1242, h=71.9 (até y=77.5)
     - régua = bottom do title em y=82.1 (faixa azul de 4-5px)
     - subtítulo: x=18, y=82.1, w=1242, h=57.3
     - footer: x=0, y=693, w=1245, h=27.2 (FULL WIDTH, sem recuo lateral)
     - PRELIMINAR: x=1129, w=151, alinhado ao bottom (fica abaixo da régua) */
}
.slide.active{ display:block; }

/* Lead title — posição exata definida pelo usuário */
.slide .lead{
  position:absolute; left:12px; top:2px;
  width:1252px;
  height:70px;
  font-size:18pt; font-weight:700; color:var(--navy);
  line-height:1.18;
  overflow:hidden;
}
.slide .lead .it{ font-style:italic; }

/* Régua azul grossa — shape do slideMaster: x=0, y=79.5, w=1280, h=5.3
   Vai de borda a borda do slide, fora das caixas de título/subhead. */
.slide::before{
  content:""; position:absolute;
  left:0; right:0; top:79px;
  height:5px; background:var(--navy);
  pointer-events:none;
  z-index:1;
}

/* Subhead — posição exata definida pelo usuário */
.slide .subhead{
  position:absolute; left:12px; top:84px;
  width:1252px; height:57px;
  font-size:var(--fs-sub); font-weight:700; color:var(--navy);
  letter-spacing:.3px;
  padding-top:8px; /* gap visual entre régua e primeira letra do subhead */
}

/* Canvas: começa abaixo do subhead (y=82+57=139), termina antes do footer (y=693) */
.slide .canvas{
  position:absolute; left:18px; right:18px;
  top:145px; bottom:38px;
}

/* Rodapé — full width (x=0, w=1245), como no PPTX.
   top ajustado pra acomodar logo de 26px sem estourar 720. */
.slide .foot{
  position:absolute; left:0; right:0; top:688px;
  height:32px;
  display:flex; justify-content:space-between; align-items:center;
  font-size:var(--fs-small);
  border-top:1px solid var(--grey-mid);
  padding:4px 18px 0;
  box-sizing:border-box;
  overflow:hidden;
}
.slide .foot .src{
  flex:1; color:var(--navy); /* fonte é AZUL, não cinza */
  padding-left:18px; /* dá um "tab" à esquerda (recuo do texto da fonte) */
}
.slide .foot .right{ display:flex; align-items:center; gap:14px; }
.slide .foot .pageno{
  color:var(--navy);
  font-variant-numeric:tabular-nums;
}
.slide .foot .brand{ display:flex; align-items:center; }

/* ============================================================
   4. COMPONENTES TRANSVERSAIS
   ============================================================ */

/* chevron de conta OM */
.chevron{
  display:inline-block; background:var(--navy); color:#fff;
  font-weight:700; font-size:var(--fs-small);
  padding:3px 18px 3px 10px;
  clip-path:polygon(0 0,calc(100% - 12px) 0,100% 50%,calc(100% - 12px) 100%,0 100%);
}
.breadcrumb{ display:flex; gap:4px; margin-top:1%; }

/* badge de função (5 canônicos) — ABAIXO da régua, alinhado à direita.
   Tem faixa navy ACIMA e ABAIXO do texto (sublinhado em cima e embaixo). */
.badge{
  position:absolute; top:115px; right:18px;
  font-weight:700; font-size:var(--fs-small);
  color:var(--navy);
  border-top:2px solid var(--navy);
  border-bottom:2px solid var(--navy);
  letter-spacing:.5px; text-transform:uppercase;
  padding:2px 0;
  z-index:5;
}
.badge.hidden{ display:none; }

/* callout de oportunidade — DEFAULT é elipse achatada (bubble) draggável.
   Dimensão padrão extraída do PPTX: w=182, h=86 (ratio w/h ≈ 2,11:1). */
.callout-opp{
  position:absolute; background:var(--maroon); color:#fff;
  font-weight:700; text-align:center;
  padding:10px 20px; line-height:1.25;
  font-size:var(--fs-body);
  width:182px; height:86px;
  border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  box-sizing:border-box;
  cursor:move;             /* indica que é draggável */
  user-select:none;        /* não selecionar texto ao arrastar */
  z-index:3;
}
.callout-opp.dragging{ opacity:.85; box-shadow:0 4px 12px rgba(0,0,0,.3); }
.callout-opp.bubble{ border-radius:50%; }
.callout-opp.rect{ border-radius:10px; }
.bubble-text{ display:inline-block; outline:none; }

/* bubble custom criado pelo botão "+ Bubble" — cor navy (#002060) em vez de bordô */
.callout-opp.custom-navy{
  background:var(--navy);
  /* CSS resize nativo: handle aparece no canto inferior direito */
  resize:both;
  overflow:auto;
  min-width:80px; min-height:40px;
}
.callout-opp.custom-navy::-webkit-resizer{
  background:rgba(255,255,255,.3);
}
/* modo edição: cursor de texto + outline visível + permite seleção */
.callout-opp.custom-navy.editing{
  cursor:text;
  user-select:text;
  -webkit-user-select:text;
  outline:2px dashed var(--orange);
  outline-offset:2px;
}
/* botão de remover (X) — aparece no hover ou quando o bubble está focado */
.bubble-delete{
  position:absolute; top:-10px; right:-10px;
  width:22px; height:22px;
  background:var(--red); color:#fff;
  border-radius:50%; border:2px solid #fff;
  font-size:13px; font-weight:700; line-height:1;
  cursor:pointer;
  display:none;
  align-items:center; justify-content:center;
  z-index:10;
  box-shadow:0 1px 4px rgba(0,0,0,.3);
}
.bubble-delete:hover{ background:#a00000; }
.callout-opp.custom-navy:hover .bubble-delete,
.callout-opp.custom-navy.editing .bubble-delete,
.callout-opp.custom-navy.selected .bubble-delete{
  display:flex;
}
.callout-opp.custom-navy.selected{
  outline:2px solid var(--orange);
  outline-offset:2px;
}

/* veredito "Sem Oportunidade" */
.verdict-none{
  position:absolute; top:60px; right:80px;
  background:var(--maroon); color:#fff;
  font-weight:700; padding:14px 22px;
  border-radius:50%/45%;
  font-size:var(--fs-body);
}

/* linha de referência (meta/mediana) */
.ref-line{
  position:absolute; left:0; right:0; height:2px;
  background:var(--red);
}
.ref-line.dashed{
  background:repeating-linear-gradient(90deg,var(--red) 0 8px,transparent 8px 14px);
}

/* tabela padrão — largura proporcional ao conteúdo, centralizada no canvas.
   Bordas POR CÉLULA (não pela linha) — emula caixas de texto independentes do PPTX,
   com gap horizontal entre colunas (border-spacing). */
.tbl{
  width:auto; max-width:100%;
  margin:0 auto;
  border-collapse:separate;        /* permite gap entre colunas */
  border-spacing:14px 0;            /* gap horizontal de 14px, sem vertical */
  font-size:var(--fs-body); color:var(--navy);
}
.tbl-full{ width:100%; }
.tbl th{ font-weight:700; text-align:left; padding:4px 6px; white-space:nowrap; vertical-align:bottom; }
.tbl th.grp{ border-bottom:1px solid var(--navy); text-align:left; }
/* th com rowspan: border-bottom alinhado com a régua das colunas da direita */
.tbl thead th[rowspan]{ border-bottom:1px solid var(--navy); }
.tbl td{ text-align:left; padding:4px 6px; white-space:nowrap; }
/* colunas numéricas: alinhar à direita explicitamente via class .num */
.tbl th.num, .tbl td.num{ text-align:right; }
.tbl th.center, .tbl td.center{ text-align:center; }
/* régua inferior do cabeçalho — POR CÉLULA, navy, com gap natural entre colunas */
.tbl thead tr:last-child th{ border-bottom:1px solid var(--navy); }
.tbl .it{ font-style:italic; }
/* régua sobre Total — POR CÉLULA, navy */
.tbl tfoot .total td{ font-weight:700; border-top:1px solid var(--navy); }
.tbl tr.zebra{ background:var(--zebra); }
/* subtotais (resumoGeral) — régua navy sobre a linha de subtotal */
.tbl tr.subtotal td{ font-weight:700; border-top:1px solid var(--navy); }
.canvas-tbl-wrap{ width:100%; height:100%; display:flex; align-items:flex-start; justify-content:center; }

/* shade móvel (buildup / mapa) */
.shade{
  position:absolute; background:var(--grey-shade);
  z-index:0;
  pointer-events:none;
}

/* contenteditable — feedback visual sutil + garantia de interação */
[contenteditable="true"]{
  outline:none;
  border-bottom:1px dashed transparent;
  transition:border-color .15s;
  cursor:text;
  user-select:text;
  -webkit-user-select:text;
  pointer-events:auto;       /* garante que nada bloqueia o clique */
  position:relative;          /* cria stacking context próprio */
  z-index:2;                  /* fica acima de pseudo-elementos do .slide */
}
[contenteditable="true"]:hover{ border-bottom-color:var(--blue-light); }
[contenteditable="true"]:focus{ border-bottom-color:var(--orange); background:#fff8ee; }
[contenteditable="false"]{ cursor:default; }
.computed{ color:var(--navy); /* valor calculado, não editável */ user-select:text; }

/* ============================================================
   5. HEADER FIXO (navegação + botões)
   ============================================================ */
.deck-header{
  position:fixed; top:0; left:0; right:0;
  height:48px; background:var(--navy); color:#fff;
  display:flex; align-items:center; padding:0 18px;
  z-index:100;
  font-size:13px;
}
.deck-header .title{ flex:1; font-weight:700; }
.deck-header .nav{ display:flex; align-items:center; gap:8px; margin-right:24px; }
.deck-header button{
  background:transparent; color:#fff; border:1px solid rgba(255,255,255,.4);
  padding:6px 12px; cursor:pointer; font-size:12px;
  border-radius:3px; font-family:var(--font);
}
.deck-header button:hover{ background:rgba(255,255,255,.1); }
.deck-header button.primary{ background:var(--orange); border-color:var(--orange); }
.deck-header .counter{ font-variant-numeric:tabular-nums; min-width:60px; text-align:center; }

body{ padding-top:48px; } /* compensa header fixo */

/* ============================================================
   6. MAPA-MESTRE — painel flutuante (drawer)
   ============================================================ */
.master-drawer{
  position:fixed; top:48px; right:-100%;
  width:720px; height:calc(100vh - 48px);
  background:var(--paper); color:var(--navy);
  box-shadow:-4px 0 24px rgba(0,0,0,.3);
  transition:right .3s ease;
  z-index:90;
  overflow-y:auto;
  padding:24px;
}
.master-drawer.open{ right:0; }
.master-drawer h2{
  margin:0 0 16px; font-size:18pt; color:var(--navy);
  border-bottom:2px solid var(--navy); padding-bottom:8px;
}
.master-drawer .hint{ font-size:11pt; color:var(--grey-mid); margin-bottom:16px; }
.master-drawer table{
  width:100%; border-collapse:collapse;
  font-size:11pt; color:var(--navy);
}
.master-drawer th, .master-drawer td{
  padding:8px 10px; text-align:left;
  border-bottom:1px solid var(--rule);
}
.master-drawer th{ background:var(--zebra); font-weight:700; }
.master-drawer td.r{ text-align:right; font-variant-numeric:tabular-nums; }
.toggle-3{ display:inline-flex; gap:2px; }
.toggle-3 button{
  padding:4px 10px; font-size:10pt;
  background:#fff; color:var(--navy);
  border:1px solid var(--rule);
  cursor:pointer; font-family:var(--font);
}
.toggle-3 button.on[data-state="preliminar"]{ background:var(--grey-shade); color:var(--navy); border-color:var(--navy); }
.toggle-3 button.on[data-state="adicional"]{ background:var(--orange); color:#fff; border-color:var(--orange); }
.toggle-3 button.on[data-state="validada"]{ background:var(--green); color:#fff; border-color:var(--green); }
.toggle-3 button:first-child{ border-radius:3px 0 0 3px; }
.toggle-3 button:last-child{ border-radius:0 3px 3px 0; }

.master-totals{
  margin-top:24px; padding:16px;
  background:var(--zebra); border-left:4px solid var(--navy);
  font-size:11pt;
}
.master-totals .row{ display:flex; justify-content:space-between; padding:4px 0; }
.master-totals .row strong{ font-weight:700; }

/* ============================================================
   6b. ANALYSIS-DRAWER — controles da ANÁLISE VIVA (Modo A)
   Painel por slide de análise: cluster / meta / cap / maxBars.
   Mexer aqui dispara recomputeAnalise() (computeBenchmarks + computeOportunidade).
   Estilo segue o master-drawer (não inventa visual novo).
   ============================================================ */
.analysis-drawer{
  position:fixed; top:48px; right:-100%;
  width:420px; height:calc(100vh - 48px);
  background:var(--paper); color:var(--navy);
  box-shadow:-4px 0 24px rgba(0,0,0,.3);
  transition:right .3s ease;
  z-index:91;
  overflow-y:auto;
  padding:24px;
}
.analysis-drawer.open{ right:0; }
.analysis-drawer h2{
  margin:0 0 8px; font-size:16pt; color:var(--navy);
  border-bottom:2px solid var(--navy); padding-bottom:8px;
}
.analysis-drawer .hint{ font-size:10pt; color:var(--grey-mid); margin-bottom:16px; }
.analysis-drawer .ctrl{ margin-bottom:16px; }
.analysis-drawer .ctrl label{ display:block; font-weight:700; font-size:10pt; margin-bottom:5px; }
.analysis-drawer select,
.analysis-drawer input[type="number"]{
  width:100%; padding:6px 8px; font-size:10pt; font-family:var(--font);
  color:var(--navy); border:1px solid var(--rule); border-radius:3px; background:#fff;
}
.analysis-drawer .row-inline{ display:flex; align-items:center; gap:8px; }
.analysis-drawer .row-inline input[type="number"]{ flex:1; }
.analysis-drawer .recompute-out{
  margin-top:18px; padding:14px;
  background:var(--zebra); border-left:4px solid var(--maroon);
  font-size:11pt;
}
.analysis-drawer .recompute-out .big{ font-size:15pt; font-weight:800; color:var(--maroon); }

/* ============================================================
   7. LOGO Gradus — PNG real embutido (marca-positiva)
   Fonte: gradus-consultant-frontend/assets/logos/logos-base64.js
   ============================================================ */
.logo-gradus{
  display:inline-block;
  height:26px; width:auto;
  vertical-align:middle;
}
/* Esconde a imagem se ainda não tiver src real (evita ícone de "imagem quebrada"). */
img.logo-gradus:not([src]),
img.logo-gradus[src=""]{
  display:none;
}

</style>
</head>
<body>

<!-- ============================================================
     HEADER FIXO — navegação + ações
     ============================================================ -->
<div class="deck-header">
  <div class="title"><!-- GEN: DECK_TITLE --> Storyline Gradus</div>
  <div class="nav">
    <button id="btn-prev">← Anterior</button>
    <span class="counter"><span id="cur">1</span> / <span id="total">1</span></span>
    <button id="btn-next">Próximo →</button>
  </div>
  <div class="actions" style="display:flex; gap:8px;">
    <button id="btn-master">Gerenciar análises</button>
    <button id="btn-create-bubble">+ Bubble</button>
    <button id="btn-save">Salvar HTML</button>
    <button id="btn-reset">Resetar</button>
    <button id="btn-export-json" class="primary">Exportar JSON</button>
  </div>
</div>

<!-- ============================================================
     PALCO — slides com scale letterbox
     ============================================================ -->
<div class="stage-wrap">
  <div class="stage" id="stage">

    <!-- ============================================================
         PONTO DE INJEÇÃO: SLIDES
         O gerador deve injetar <section class="slide" data-id="..."> blocos aqui
         na ordem canônica: placar → buildup → (VGC + mapa + análises)×conta → OOI
         Cada slide segue o esqueleto abaixo (comentado).
         ============================================================ -->

    <!-- EXEMPLO DE SLIDE 1 — PLACAR (template canonical: pacote-opportunity-summary)
    <section class="slide active" data-id="placar-001" data-role="pacote-opportunity-summary">
      <h1 class="lead" contenteditable="true">
        {PACOTE CAPS} | Placar de oportunidades
      </h1>
      <div class="subhead" contenteditable="true">R$ MM/ano</div>
      <div class="canvas">
        <table class="tbl">
          <thead>
            <tr>
              <th rowspan="2">Conta OM</th>
              <th rowspan="2" class="it">Baseline</th>
              <th colspan="2" class="grp">Oportunidades validadas</th>
              <th colspan="2" class="grp">Oportunidades adicionais</th>
            </tr>
            <tr>
              <th>R$/ano</th><th>% Baseline</th>
              <th>R$/ano</th><th>% Baseline</th>
            </tr>
          </thead>
          <tbody>
            <tr><td contenteditable="true">Conta 1</td>
                <td class="computed">60,5</td>
                <td class="computed">—</td><td class="computed">—</td>
                <td class="computed">3,2</td><td class="computed">5,3%</td></tr>
          </tbody>
          <tfoot>
            <tr class="total"><td>Total</td>
                <td class="computed">60,5</td>
                <td class="computed">—</td><td>—</td>
                <td class="computed">3,2</td><td>5,3%</td></tr>
          </tfoot>
        </table>
      </div>
      <footer class="foot">
        <span class="src" contenteditable="true">Fonte: Realizado contábil jan/2024 a dez/2024</span>
        <span class="pageno">1</span>
        <span class="brand"><span class="logo-gradus"></span></span>
      </footer>
    </section>
    -->

    <!-- GEN: SLIDES — injete aqui -->

    <section class="slide active" data-id="placar-001" data-role="pacote-opportunity-summary">
      <h1 class="lead" contenteditable="true">CONECTIVIDADE | Placar de oportunidades</h1>
      <div class="subhead" contenteditable="true">R$ MM/ano</div>
      <div class="canvas">
        <div class="canvas-tbl-wrap">
          <table class="tbl">
            <thead>
              <tr><th rowspan="2">Conta OM</th><th rowspan="2" class="it num">Baseline</th>
                <th colspan="2" class="grp">Oportunidades validadas</th>
                <th colspan="2" class="grp">Oportunidades adicionais</th></tr>
              <tr><th class="num">Valor</th><th class="num">% Baseline</th><th class="num">Valor</th><th class="num">% Baseline</th></tr>
            </thead>
            <tbody>
              <tr><td contenteditable="true">Rede Telefonia Terceira</td><td class="computed num">60,5</td><td class="computed num">&mdash;</td><td class="computed num">&mdash;</td><td class="computed num">3,2</td><td class="computed num">5,3%</td></tr>
              <tr><td contenteditable="true">Dados</td><td class="computed num">22,0</td><td class="computed num">&mdash;</td><td class="computed num">&mdash;</td><td class="computed num">1,8</td><td class="computed num">8,2%</td></tr>
            </tbody>
            <tfoot><tr class="total"><td>Total</td><td class="computed num">82,5</td><td class="computed num">&mdash;</td><td class="num">&mdash;</td><td class="computed num">5,0</td><td class="num">6,1%</td></tr></tfoot>
          </table>
        </div>
      </div>
      <footer class="foot">
        <span class="src" contenteditable="true">Fonte: Realizado contabil jan/2024 a dez/2024</span>
        <span class="right"><span class="brand"><img class="logo-gradus" alt="Gradus"></span><span class="pageno">1</span></span>
      </footer>
    </section>

    <!-- buildup HARDCODED ORIGINAL substituído por render via renderBuildup().
         O markup estático abaixo serve de FALLBACK (impressão/sem-JS); a função
         redesenha #buildup-bars com shade no focusIndex via dado-exemplo. -->
    <section class="slide" data-id="buildup-001" data-role="buildup-pacote">
      <h1 class="lead" contenteditable="true">CONECTIVIDADE | Detalhamento do pacote</h1>
      <div class="subhead" contenteditable="true">R$ MM/ano</div>
      <div class="canvas" style="padding:30px 0 0;">
        <!-- Container 810 centralizado: 90px reservados à esq pro label "% do pacote".
             renderBuildup() preenche #buildup-bars (este DIV é o container relativo
             das barras — e o shade entra como filho DELE, nunca de .canvas) (R3). -->
        <div style="width:810px; margin:0 auto;">
          <div id="buildup-bars" style="position:relative; width:810px; height:400px;"><!-- GEN/render: renderBuildup() --></div>
          <div id="buildup-labels" style="position:relative; height:48px; margin-top:8px;"></div>
          <div id="buildup-pct" style="position:relative; margin-top:16px; height:24px;"></div>
        </div>
      </div>
      <footer class="foot">
        <span class="src" contenteditable="true">Fonte: Realizado contabil jan/2024 a dez/2024</span>
        <span class="right"><span class="brand"><img class="logo-gradus" alt="Gradus"></span><span class="pageno">2</span></span>
      </footer>
    </section>

    <section class="slide" data-id="mapa-001" data-role="mapa-de-analises">
      <h1 class="lead" contenteditable="true">REDE TELEFONIA TERCEIRA | Mapa de análises (R$ MM/ano)</h1>
      <div class="subhead" contenteditable="true">R$ MM/ano</div>
      <div class="canvas">
        <div class="canvas-tbl-wrap">
          <table class="tbl">
            <thead>
              <tr><th rowspan="2">Natureza do gasto</th><th rowspan="2" class="it num">Baseline</th>
                <th colspan="2" class="grp">Oportunidade</th>
                <th rowspan="2">Fator</th><th rowspan="2">Análises</th></tr>
              <tr><th class="num">Validada</th><th class="num">Adicional</th></tr>
            </thead>
            <tbody>
              <tr><td contenteditable="true">Telefonia móvel</td><td class="computed num">38,0</td><td class="computed num">&mdash;</td><td class="computed num">3,2</td><td contenteditable="true">Preço</td><td contenteditable="true">Comparação R$/min por cluster</td></tr>
              <tr><td contenteditable="true">Interurbana</td><td class="computed num">14,5</td><td class="computed num">&mdash;</td><td class="computed num">&mdash;</td><td contenteditable="true">Consumo</td><td contenteditable="true">Sem oportunidade</td></tr>
              <tr><td contenteditable="true">Local</td><td class="computed num">8,0</td><td class="computed num">&mdash;</td><td class="computed num">&mdash;</td><td contenteditable="true">Total</td><td contenteditable="true">Sem oportunidade</td></tr>
            </tbody>
            <tfoot><tr class="total"><td>Total</td><td class="computed num">60,5</td><td class="computed num">&mdash;</td><td class="computed num">3,2</td><td>&mdash;</td><td>&mdash;</td></tr></tfoot>
          </table>
        </div>
      </div>
      <footer class="foot">
        <span class="src" contenteditable="true">Fonte: Realizado contabil jan/2024 a dez/2024; análise sobre Base SAP-CO 2024</span>
        <span class="right"><span class="brand"><img class="logo-gradus" alt="Gradus"></span><span class="pageno">3</span></span>
      </footer>
    </section>

    <section class="slide" data-id="analise-001" data-role="análise" data-analysis-id="a1">
      <span class="badge" data-badge="PRELIMINAR">PRELIMINAR</span>
      <h1 class="lead" contenteditable="true">A oportunidade concentra-se em renegociação tarifária com tres operadoras, valendo R$ 3,2 MM/ano</h1>
      <div class="subhead" contenteditable="true">REDE TELEFONIA TERCEIRA · R$ MM/ano</div>
      <div class="canvas" style="padding-top:24px;">
        <p contenteditable="true" style="max-width:760px;">"+ Bubble" cria bubble navy. Duplo clique edita. Click 1x seleciona. Delete remove. Arraste pra mover.</p>
        <div class="callout-opp bubble" style="left:1000px; top:240px;">Oportunidade<br>R$ 3,2 MM (5,3%)</div>
      </div>
      <footer class="foot">
        <span class="src" contenteditable="true">Fonte: Realizado contabil jan/2024 a dez/2024; análise sobre Base SAP-CO 2024</span>
        <span class="right"><span class="brand"><img class="logo-gradus" alt="Gradus"></span><span class="pageno">4</span></span>
      </footer>
    </section>

    <!-- ============================================================
         EXEMPLO: a skill injeta dados reais aqui
         3 slides de EXEMPLO p/ os renderers portados (tornado / análise-viva / resumo-geral).
         Os dados vivem em DEMO.* no <script> (placeholder) — a skill substitui por dados reais.
         ============================================================ -->

    <!-- EXEMPLO renderTornado: ranking SVG (barras ordenadas + ref-line mediana + labels rotacionados + seta) -->
    <section class="slide" data-id="ex-tornado" data-role="análise" data-analysis-id="a2"
             data-render="tornado" data-target="svg-tornado">
