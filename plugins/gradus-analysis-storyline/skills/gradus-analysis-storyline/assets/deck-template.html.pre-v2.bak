/* ============================================================
   12h. DISPATCH — renderActive(): redesenha o slide ativo por data-render
   Padrão equivalente ao renderActive() do v3 (dispatch por id), mas
   guiado por data-render/data-target no <section> (mais portável p/ a skill).
   ============================================================ */
function renderActive(){
  const slide = document.querySelector('.slide.active'); if(!slide) return;
  const kind = slide.dataset.render;
  const tgt  = slide.dataset.target;

  if(kind === 'tornado'){
    renderTornado(tgt, DEMO.tornado.data, {meta:DEMO.tornado.meta, maxBars:DEMO.tornado.maxBars, dec:DEMO.tornado.dec, indLabel:DEMO.tornado.indLabel});
  }
  else if(kind === 'analiseViva'){
    const b = slide.dataset.bucket || DEMO.analiseViva.bucket;
    if(!BUCKET_STATES[b]){
      BUCKET_STATES[b] = makeBucketState(b);
      BUCKET_STATES[b]._lastUnits = DEMO.analiseViva.units;   // skill injeta units reais
      BUCKET_STATES[b].indicador = 'r_10k_driver';
      BUCKET_STATES[b].maxBars = 12;
    }
    // host: ranking SVG das unidades + tabela leve (reaproveita o tornado p/ visual)
    const host = document.getElementById(tgt);
    if(host && !host.querySelector('svg')){
      host.innerHTML = '<svg id="av-svg" viewBox="0 0 980 420" width="78%" height="100%" preserveAspectRatio="xMidYMid meet"></svg>';
    }
    const st = BUCKET_STATES[b];
    const rows = st._lastUnits.map(u => ({label:u.id, valor: u.driver>0 ? +(u.gasto/(u.driver/10000)).toFixed(2) : 0}));
    renderTornado('av-svg', rows, {meta:st.meta, maxBars:st.maxBars, dec:2, indLabel:'R$/10k driver'});
    recomputeAnalise(b);
  }
  else if(kind === 'resumoGeral'){
    renderResumoGeral(tgt, DEMO.resumoGeral.groups, {valLabel:DEMO.resumoGeral.valLabel, grpLabel:DEMO.resumoGeral.grpLabel, dec:DEMO.resumoGeral.dec});
  }
  else if(slide.dataset.id === 'buildup-001'){
    // buildup-pacote: foca a 1ª barra como exemplo do shade móvel
    renderBuildup('buildup-bars', DEMO.buildup.bars, {
      total: DEMO.buildup.total, totalLabel: DEMO.buildup.totalLabel, pctBase: DEMO.buildup.pctBase,
      focusIndex: 0, labelsId:'buildup-labels', pctId:'buildup-pct'
    });
  }
  // re-aplica binds nos elementos recém-criados
  bindEditable(); bindDraggable();
  checkOverflow(slide);
}

/* ============================================================
   13. MAPA-MESTRE — drawer + toggle 3 estados
   ============================================================ */
/* drawer e btn-master bindados em init() */
let drawer;

function renderMaster(){
  // calcula totais
  let tV = 0, tA = 0, tP = 0;
  STATE.analyses.forEach(a => {
    const v = parseFloat(a.value) || 0;
    if(a.state === 'validada') tV += v;
    else if(a.state === 'adicional') tA += v;
    else tP += v;
  });
  const fmt = n => `R$ ${n.toFixed(1).replace('.', ',')} MM`;
  document.getElementById('tot-validada').textContent = fmt(tV);
  document.getElementById('tot-adicional').textContent = fmt(tA);
  document.getElementById('tot-preliminar').textContent = fmt(tP);

  // re-render do estado dos botões
  document.querySelectorAll('.toggle-3').forEach(tg => {
    const aid = tg.dataset.analysisId;
    const analysis = STATE.analyses.find(a => a.id === aid);
    if(!analysis) return;
    tg.querySelectorAll('button').forEach(btn => {
      btn.classList.toggle('on', btn.dataset.state === analysis.state);
    });
  });
}

// click handler para toggle (event delegation)
document.addEventListener('click', (e) => {
  const btn = e.target.closest('.toggle-3 button');
  if(!btn) return;
  const tg = btn.closest('.toggle-3');
  const aid = tg.dataset.analysisId;
  const newState = btn.dataset.state;

  const analysis = STATE.analyses.find(a => a.id === aid);
  if(!analysis) return;

  analysis.state = newState;
  saveState();
  renderMaster();
  propagateClassification(aid, newState);
});

function propagateClassification(analysisId, state){
  // 1. Liga/desliga badge PRELIMINAR no slide individual
  const slide = document.querySelector(`.slide[data-analysis-id="${analysisId}"]`);
  if(slide){
    const badge = slide.querySelector('.badge[data-badge="PRELIMINAR"]');
    if(badge) badge.classList.toggle('hidden', state !== 'preliminar');
  }

  // 2. Atualiza linha no mapa-de-análises por conta (R$ aparece/some)
  document.querySelectorAll(`[data-mapa-row-analysis="${analysisId}"]`).forEach(row => {
    const valCell = row.querySelector('.r-valor');
    if(!valCell) return;
    const analysis = STATE.analyses.find(a => a.id === analysisId);
    if(state === 'preliminar'){
      valCell.textContent = '—'; // ou R$ 0,0 — convenção: linha continua, mas valor não soma
    } else {
      valCell.textContent = `R$ ${parseFloat(analysis.value).toFixed(1).replace('.', ',')} MM`;
    }
  });
  rerenderPlacar();
}

function rerenderPlacar(){
  console.log('[placar] re-render triggered');
}

function exportJSON(){
  const json = JSON.stringify(STATE, null, 2);
  const blob = new Blob([json], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `storyline-state-${Date.now()}.json`;
  a.click();
  URL.revokeObjectURL(url);
}

function saveAsHTML(){
  const html = '<!DOCTYPE html>\n' + document.documentElement.outerHTML;
  const blob = new Blob([html], { type: 'text/html' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `storyline-${Date.now()}.html`;
  a.click();
  URL.revokeObjectURL(url);
}

function init(){
  try {
    loadState();
    applyLogos();
    applyScale();
    bindEditable();
    bindDraggable();
    bindAnalysisDrawer();

    drawer = document.getElementById('master-drawer');
    const adrawer = document.getElementById('analysis-drawer');
    document.getElementById('btn-prev').addEventListener('click', () => showSlide(STATE.currentSlide - 1));
    document.getElementById('btn-next').addEventListener('click', () => showSlide(STATE.currentSlide + 1));
    document.getElementById('btn-master').addEventListener('click', () => {
      drawer.classList.toggle('open');
      renderMaster();
    });
    document.getElementById('btn-export-json').addEventListener('click', exportJSON);
    document.getElementById('btn-save').addEventListener('click', saveAsHTML);
    document.getElementById('btn-reset').addEventListener('click', resetState);
    document.getElementById('btn-create-bubble').addEventListener('click', createBubble);

    renderMaster();
    showSlide(STATE.currentSlide || 0);   // showSlide chama renderActive()
    getSlides().forEach(s => checkOverflow(s));
  } catch(e) {
    console.error('[init] erro:', e);
    alert('Erro na inicialização do deck: ' + e.message);
  }
}
window.addEventListener('load', init);
</script>

</body>
</html>
